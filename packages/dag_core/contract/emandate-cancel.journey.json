          "next": "n_done"
        }
      ],
      "default": "n_notFound"
    },
    {
      "id": "n_done",
      "type": "terminal",
      "action": "notify_channel",
      "emit": [
        "MandateCancelled"
      ],
      "status": "completed"
    },
    {
      "id": "n_notFound",
      "type": "terminal",
      "action": "notify_channel",
      "emit": [
        "MandateNotFound"
      ],
      "status": "rejected"
    }
  ],
  "layout": {
