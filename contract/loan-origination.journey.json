{
  "journeyKey": "loan-origination",
  "version": 1,
  "context": {
    "schemaRef": "loan-origination-context@1"
  },
  "pools": {
    "finnone_pool": {
      "maxConcurrent": 20
    }
  },
  "startNodeId": "n_customer",
  "nodes": [
    {
      "id": "n_customer",
      "type": "task",
      "capability": "customer-party",
      "operation": "resolve",
      "output": "context.customer",
      "next": [
        "n_kyc"
      ]
    },
    {
      "id": "n_kyc",
      "type": "task",
      "capability": "kyc",
      "operation": "verify",
      "output": "context.kyc",
      "next": [
        "n_bureau"
      ]
    },
    {
      "id": "n_bureau",
      "type": "task",
      "capability": "bureau",
      "operation": "pull",
      "output": "context.bureau",
      "next": [
        "n_score"
      ]
    },
    {
      "id": "n_score",
      "type": "task",
      "capability": "scoring",
      "operation": "decide",
      "output": "context.scoring",
      "next": [
        "n_decide"
      ]
    },
    {
      "id": "n_decide",
      "type": "branch",
      "arms": [
        {
          "when": "context.scoring.decision == 'APPROVED'",
          "next": "n_book"
        }
      ],
      "default": "n_reject"
    },
    {
      "id": "n_book",
      "type": "task",
      "capability": "lending-origination",
      "operation": "book",
      "output": "context.loan",
      "next": [
        "n_done"
      ],
      "onFailure": "compensate",
      "policies": {
        "meter": {
          "pool": "finnone_pool"
        }
      },
      "compensation": {
        "operation": "reverseBooking",
        "input": "{ loanId: context.loan.id }"
      }
    },
    {
      "id": "n_done",
      "type": "terminal",
      "action": "push_decision_to_channel",
      "emit": [
        "LoanBooked"
      ],
      "status": "completed"
    },
    {
      "id": "n_reject",
      "type": "terminal",
      "action": "push_decision_to_channel",
      "emit": [
        "LoanRejected"
      ],
      "status": "rejected"
    }
  ],
  "layout": {
    "n_customer": {
      "x": 80.0,
      "y": 200.0
    },
    "n_kyc": {
      "x": 260.0,
      "y": 200.0
    },
    "n_bureau": {
      "x": 440.0,
      "y": 200.0
    },
    "n_score": {
      "x": 620.0,
      "y": 200.0
    },
    "n_decide": {
      "x": 800.0,
      "y": 200.0
    },
    "n_book": {
      "x": 980.0,
      "y": 120.0
    },
    "n_done": {
      "x": 1160.0,
      "y": 120.0
    },
    "n_reject": {
      "x": 980.0,
      "y": 300.0
    }
  }
}
